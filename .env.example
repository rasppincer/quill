# Quill environment variables
# Copy to .env and fill in values. .env is gitignored.

# LLM API key (for OpenAI, Anthropic, or other cloud providers)
# Leave empty for local LLMs that don't need auth
QUILL_API_KEY=

# Optional: override API base from model.yaml
# QUILL_API_BASE=http://localhost:1234/v1
